[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "npfseir"]
	path = npfseir
	url = https://github.com/cran/npfseir
[submodule "seairmobility"]
	path = seairmobility
	url = https://github.com/cran/seairmobility
[submodule "seirMFG"]
	path = seirMFG
	url = https://github.com/cran/seirMFG
